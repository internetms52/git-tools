#!/bin/bash

UPSTREAM=${1:-main}
CURRENT=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT" = "$UPSTREAM" ]; then
  echo "Already on $UPSTREAM, no rebase needed"
  exit 1
fi

# Find the divergence point between the feature branch and upstream
BASE=$(git merge-base $UPSTREAM $CURRENT)

# Collect revert commits that need to be undone
REVERTS_TO_UNDO=()

# Scan all revert commits on upstream after the divergence point
while IFS= read -r HASH; do
  # Extract the original hash that this revert commit points to
  REVERTED_HASH=$(git show $HASH --format="%B" | grep "This reverts commit" | awk '{print $4}' | tr -d '.')

  if [ -z "$REVERTED_HASH" ]; then
    continue
  fi

  # Determine whether it was a regular merge or squash merge by checking parent count
  PARENT_COUNT=$(git log --pretty=%P -n 1 $REVERTED_HASH | tr ' ' '\n' | grep -c .)

  if [ "$PARENT_COUNT" -gt 1 ]; then
    # Method 1: regular merge — check if any non-first parent of the merge commit is an ancestor of CURRENT
    FEATURE_PARENTS=$(git log --pretty=%P -n 1 $REVERTED_HASH | tr ' ' '\n' | tail -n +2)
    for PARENT in $FEATURE_PARENTS; do
      if git merge-base --is-ancestor $PARENT $CURRENT 2>/dev/null; then
        echo "Detected $HASH as a revert targeting this branch (regular merge)"
        REVERTS_TO_UNDO+=("$HASH")
        break
      fi
    done
  else
    # Method 2: squash merge — look for squash-source-sha in the reverted commit message
    SOURCE_SHA=$(git show $REVERTED_HASH --format="%B" | grep "squash-source-sha:" | awk '{print $2}')

    if [ -z "$SOURCE_SHA" ]; then
      continue
    fi

    # Check if squash-source-sha is an ancestor of the current branch
    if git merge-base --is-ancestor $SOURCE_SHA $CURRENT 2>/dev/null; then
      echo "Detected $HASH as a revert targeting this branch (squash merge)"
      REVERTS_TO_UNDO+=("$HASH")
    fi
  fi

done < <(git log $UPSTREAM ^$BASE --format="%H")

# Rebase first
echo "Starting rebase onto $UPSTREAM..."
git rebase $UPSTREAM

if [ $? -ne 0 ]; then
  echo "Error: rebase failed"
  exit 1
fi

# After rebase, revert the upstream revert commits that targeted this branch
for REVERT_HASH in "${REVERTS_TO_UNDO[@]}"; do
  echo "Reverting upstream revert commit: $REVERT_HASH"
  git revert $REVERT_HASH

  if [ $? -ne 0 ]; then
    echo "Error: could not revert $REVERT_HASH, please resolve manually"
    exit 1
  fi
done

echo "Done!"
